// ══ NAVIGATION ════════════════════════════════════════════
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  const labels = { reglement:'RÈGLEMENT GÉNÉRAL', metiers:'MÉTIERS & RÔLES', admin:'COMMANDES ADMIN', sanctions:'SANCTIONS' };
  document.getElementById('path-label').textContent = labels[name] || name.toUpperCase();
  if (name === 'metiers') renderJobs('all');
  if (name === 'admin') renderCommands();
}

// ══ JOBS ══════════════════════════════════════════════════
let currentCat = 'all';

function filterCat(cat) {
  currentCat = cat;
  // Mise à jour des tabs
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => {
    if (t.textContent.includes(cat === 'all' ? 'TOUS' : cat.toUpperCase().substr(0,5))) {
      t.classList.add('active');
    }
  });
  renderJobs(cat);
}

function renderJobs(cat) {
  const grid = document.getElementById('jobs-grid');
  const list = cat === 'all' ? JOBS : JOBS.filter(j => j.cat === cat);
  document.getElementById('job-count-footer').textContent = list.length + ' POSTES AFFICHÉS';
  grid.innerHTML = list.map(job => `
    <div class="job-card">
      <div class="job-card-header">
        <div class="job-color-bar" style="background:${job.col}"></div>
        <div>
          <div class="job-card-title">${job.name}</div>
          <div class="job-card-cmd">/${job.cmd} — ${job.cat}</div>
        </div>
        <div class="job-card-badges">
          ${job.wl ? '<span class="badge badge-wl">WHITELIST</span>' : ''}
          <span class="badge badge-max">MAX ${job.max === 0 ? '∞' : job.max}</span>
          <span class="badge badge-sal">${job.sal}$/min</span>
        </div>
      </div>
      <div class="job-card-body">
        <div class="job-desc">${job.desc}</div>
        <ul class="job-rules">${job.rules.map(r => `<li>${r}</li>`).join('')}</ul>
      </div>
    </div>
  `).join('');
}

// ══ COMMANDES ═════════════════════════════════════════════
const PERM_LABELS = { tous:'TOUS', operator:'OPERATOR', admin:'ADMIN', sadmin:'SUPERADMIN' };
const PERM_CLASSES = { tous:'perm-tous', operator:'perm-op', admin:'perm-admin', sadmin:'perm-sadmin' };

function renderCmdList(containerId, list) {
  const el = document.getElementById(containerId);
  el.innerHTML = list.map(c => `
    <div class="cmd-item">
      <div class="cmd-syntax">${c.cmd}</div>
      <div class="cmd-desc">${c.desc}</div>
      <span class="cmd-perm ${PERM_CLASSES[c.perm]}">${PERM_LABELS[c.perm]}</span>
    </div>
  `).join('');
}

function renderCommands() {
  renderCmdList('cmd-custom',       COMMANDS.custom);
  renderCmdList('cmd-ulx-players',  COMMANDS.ulxPlayers);
  renderCmdList('cmd-ulx-sanctions',COMMANDS.ulxSanctions);
  renderCmdList('cmd-ulx-mod',      COMMANDS.ulxMod);
  renderCmdList('cmd-xp',           COMMANDS.xp);
  renderCmdList('cmd-tech',         COMMANDS.tech);
  renderCmdList('cmd-players',      COMMANDS.players);
}

// ══ INIT ══════════════════════════════════════════════════
renderJobs('all');
