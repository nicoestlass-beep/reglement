<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SITE-09 — Règlement & Documentation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --red:      #c8141e;
  --red-dim:  #6a0a0e;
  --red-glow: rgba(200,20,30,0.15);
  --bg:       #05060a;
  --bg2:      #090b10;
  --bg3:      #0d1018;
  --border:   #1e2330;
  --border2:  #2a3040;
  --text:     #c8cdd8;
  --text-dim: #5a6070;
  --text-hi:  #e8edf8;
  --cyan:     #1ab8cc;
  --orange:   #e07820;
  --green:    #1a9a4a;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Rajdhani', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Grain overlay ───────────────────────────── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1000;
  opacity: 0.6;
}

/* ── SIDEBAR ─────────────────────────────────── */
.sidebar {
  position: fixed;
  left: 0; top: 0;
  width: 260px;
  height: 100vh;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  z-index: 100;
  overflow-y: auto;
}

.sidebar-logo {
  padding: 28px 24px 20px;
  border-bottom: 1px solid var(--border);
}

.sidebar-logo .site-id {
  font-family: 'Orbitron', monospace;
  font-size: 22px;
  font-weight: 900;
  color: var(--red);
  letter-spacing: 3px;
  line-height: 1;
}

.sidebar-logo .site-sub {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--text-dim);
  letter-spacing: 2px;
  margin-top: 6px;
}

.sidebar-logo .clearance {
  display: inline-block;
  margin-top: 10px;
  padding: 3px 10px;
  background: var(--red-dim);
  border: 1px solid var(--red);
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: var(--red);
  letter-spacing: 2px;
}

.nav-section {
  padding: 16px 0 8px;
}

.nav-section-label {
  padding: 0 24px 8px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  color: var(--text-dim);
  letter-spacing: 3px;
  text-transform: uppercase;
}

.nav-item {
  display: block;
  padding: 9px 24px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-dim);
  text-decoration: none;
  letter-spacing: 0.5px;
  transition: all 0.2s;
  border-left: 2px solid transparent;
  cursor: pointer;
}

.nav-item:hover, .nav-item.active {
  color: var(--text-hi);
  background: var(--red-glow);
  border-left-color: var(--red);
}

.nav-item .nav-badge {
  float: right;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  padding: 2px 6px;
  background: var(--border);
  color: var(--text-dim);
  border-radius: 2px;
}

.nav-item.active .nav-badge {
  background: var(--red-dim);
  color: var(--red);
}

.nav-divider {
  height: 1px;
  background: var(--border);
  margin: 8px 0;
}

/* ── MAIN ────────────────────────────────────── */
.main {
  margin-left: 260px;
  min-height: 100vh;
}

/* ── HEADER ──────────────────────────────────── */
.top-bar {
  position: sticky;
  top: 0;
  background: rgba(5,6,10,0.96);
  border-bottom: 1px solid var(--border);
  padding: 12px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
  z-index: 50;
  backdrop-filter: blur(8px);
}

.top-bar-path {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 1px;
}

.top-bar-path span { color: var(--red); }

.top-bar-status {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--green);
}

.top-bar-status::before {
  content: '';
  width: 6px; height: 6px;
  background: var(--green);
  border-radius: 50%;
  animation: blink 2s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* ── PAGE ────────────────────────────────────── */
.page { display: none; padding: 40px; }
.page.active { display: block; }

/* ── HERO ────────────────────────────────────── */
.hero {
  border: 1px solid var(--border2);
  background: linear-gradient(135deg, var(--bg3) 0%, var(--bg2) 100%);
  padding: 48px;
  margin-bottom: 40px;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: 'SITE-09';
  position: absolute;
  right: -20px; top: -20px;
  font-family: 'Orbitron', monospace;
  font-size: 120px;
  font-weight: 900;
  color: rgba(200,20,30,0.04);
  pointer-events: none;
  line-height: 1;
}

.hero-corner {
  position: absolute;
  width: 20px; height: 20px;
}
.hero-corner.tl { top: 0; left: 0; border-top: 2px solid var(--red); border-left: 2px solid var(--red); }
.hero-corner.tr { top: 0; right: 0; border-top: 2px solid var(--red); border-right: 2px solid var(--red); }
.hero-corner.bl { bottom: 0; left: 0; border-bottom: 2px solid var(--red); border-left: 2px solid var(--red); }
.hero-corner.br { bottom: 0; right: 0; border-bottom: 2px solid var(--red); border-right: 2px solid var(--red); }

.hero-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--red);
  letter-spacing: 4px;
  margin-bottom: 12px;
}

.hero h1 {
  font-family: 'Orbitron', monospace;
  font-size: 32px;
  font-weight: 900;
  color: var(--text-hi);
  letter-spacing: 2px;
  margin-bottom: 12px;
}

.hero h1 span { color: var(--red); }

.hero p {
  font-size: 15px;
  color: var(--text-dim);
  max-width: 600px;
  line-height: 1.6;
}

/* ── SECTION ─────────────────────────────────── */
.section {
  margin-bottom: 40px;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}

.section-header h2 {
  font-family: 'Orbitron', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--text-hi);
  letter-spacing: 2px;
}

.section-accent {
  width: 4px;
  height: 20px;
  background: var(--red);
}

.section-count {
  margin-left: auto;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--text-dim);
  background: var(--border);
  padding: 3px 8px;
}

/* ── JOB CARDS ───────────────────────────────── */
.jobs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 16px;
}

.job-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 0;
  transition: border-color 0.2s, transform 0.2s;
  cursor: default;
  overflow: hidden;
}

.job-card:hover {
  border-color: var(--border2);
  transform: translateY(-2px);
}

.job-card-header {
  padding: 14px 18px;
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid var(--border);
}

.job-color-bar {
  width: 4px;
  height: 36px;
  border-radius: 2px;
  flex-shrink: 0;
}

.job-card-title {
  font-family: 'Rajdhani', sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: var(--text-hi);
  line-height: 1.2;
}

.job-card-cmd {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--text-dim);
  margin-top: 2px;
}

.job-card-badges {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  gap: 3px;
  align-items: flex-end;
}

.badge {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  padding: 2px 7px;
  letter-spacing: 1px;
}

.badge-wl  { background: rgba(200,20,30,0.15); color: var(--red); border: 1px solid var(--red-dim); }
.badge-max { background: var(--border); color: var(--text-dim); }
.badge-sal { background: rgba(26,154,74,0.1); color: var(--green); }

.job-card-body {
  padding: 14px 18px;
}

.job-desc {
  font-size: 13px;
  color: var(--text-dim);
  line-height: 1.5;
  margin-bottom: 12px;
}

.job-rules {
  list-style: none;
}

.job-rules li {
  font-size: 12px;
  color: var(--text);
  padding: 4px 0;
  padding-left: 14px;
  position: relative;
  line-height: 1.4;
}

.job-rules li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--red);
  font-weight: 700;
}

/* ── REGLE GLOBALE ───────────────────────────── */
.rule-block {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-left: 3px solid var(--red);
  padding: 16px 20px;
  margin-bottom: 12px;
}

.rule-block h3 {
  font-family: 'Orbitron', monospace;
  font-size: 11px;
  color: var(--red);
  letter-spacing: 2px;
  margin-bottom: 8px;
}

.rule-block p, .rule-block li {
  font-size: 13px;
  color: var(--text);
  line-height: 1.6;
}

.rule-block ul {
  list-style: none;
  padding: 0;
}

.rule-block ul li {
  padding: 3px 0 3px 16px;
  position: relative;
}

.rule-block ul li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--text-dim);
}

/* ── SANCTION TABLE ──────────────────────────── */
.sanction-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.sanction-table th {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--text-dim);
  text-align: left;
  padding: 10px 16px;
  background: var(--bg3);
  border-bottom: 1px solid var(--border2);
}

.sanction-table td {
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  color: var(--text);
  vertical-align: top;
}

.sanction-table tr:hover td { background: var(--red-glow); }

.sev-1 { color: var(--orange); }
.sev-2 { color: #e04020; }
.sev-3 { color: var(--red); font-weight: 600; }

/* ── COMMANDES ───────────────────────────────── */
.cmd-grid {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cmd-item {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 14px 18px;
  display: grid;
  grid-template-columns: 240px 1fr auto;
  gap: 16px;
  align-items: start;
  transition: border-color 0.15s;
}

.cmd-item:hover { border-color: var(--border2); }

.cmd-syntax {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px;
  color: var(--cyan);
  word-break: break-all;
}

.cmd-desc {
  font-size: 13px;
  color: var(--text);
  line-height: 1.4;
}

.cmd-perm {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px;
  padding: 3px 8px;
  white-space: nowrap;
  align-self: flex-start;
}

.perm-op      { background: rgba(200,20,30,0.12); color: #e06868; border: 1px solid var(--red-dim); }
.perm-admin   { background: rgba(200,20,30,0.18); color: var(--red); border: 1px solid var(--red); }
.perm-sadmin  { background: rgba(200,20,30,0.25); color: #ff4444; border: 1px solid #c01010; }
.perm-tous    { background: rgba(26,154,74,0.12); color: var(--green); border: 1px solid #1a4a2a; }

/* ── TABS ────────────────────────────────────── */
.tab-bar {
  display: flex;
  gap: 2px;
  margin-bottom: 28px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 0;
}

.tab {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 10px 20px;
  cursor: pointer;
  color: var(--text-dim);
  border: 1px solid transparent;
  border-bottom: none;
  transition: all 0.2s;
  background: transparent;
  margin-bottom: -1px;
}

.tab:hover { color: var(--text); }
.tab.active {
  color: var(--red);
  border-color: var(--border);
  border-bottom-color: var(--bg);
  background: var(--bg);
}

.tab-content { display: none; }
.tab-content.active { display: block; }

/* ── AVERTISSEMENT ───────────────────────────── */
.warning-box {
  background: rgba(200,20,30,0.06);
  border: 1px solid var(--red-dim);
  border-left: 3px solid var(--red);
  padding: 14px 18px;
  margin-bottom: 20px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.warning-icon {
  font-size: 16px;
  flex-shrink: 0;
  line-height: 1.4;
}

.warning-text {
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
}

/* ── FOOTER ──────────────────────────────────── */
.page-footer {
  margin-top: 60px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  color: var(--text-dim);
  letter-spacing: 1px;
  display: flex;
  justify-content: space-between;
}

/* ── SCROLL BAR ──────────────────────────────── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); }
::-webkit-scrollbar-thumb:hover { background: var(--red-dim); }

/* ── ANIMATIONS ──────────────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.page.active { animation: fadeIn 0.25s ease; }
</style>
</head>
